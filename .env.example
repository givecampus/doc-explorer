# By default, docs are read from the docs/ folder in this project.
# No configuration needed to get started.

# To point at a different local repo instead:
# LOCAL_REPO_ROOT=/path/to/other-repo

# Or fetch docs from GitHub (requires a token):
# GITHUB_TOKEN=
# GITHUB_OWNER=givecampus
# GITHUB_REPO=givecampus
# GITHUB_REF=staging

# Subdirectory in the repo where markdown docs live (default: docs)
# DOCS_PATH=docs
